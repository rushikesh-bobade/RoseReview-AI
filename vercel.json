{
  "version": 2,
  "framework": "vite",
  "buildCommand": "pnpm --filter @rosereview/api prisma:generate && pnpm --filter @rosereview/web build",
  "outputDirectory": "apps/web/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ]
}
